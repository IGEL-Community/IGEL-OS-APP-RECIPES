<sessions>
	<flameshot%>
		extends_base=<sessions.base%>
		node_action=<wm_postsetup>
	</flameshot%>
  <flameshot0>
		<name_localized>
			displayname[en_us]=<Flameshot>
		</name_localized>
		<icon>
            value=</services/flameshot/.icons/app.svg>
		</icon>
		<type>
			displayname[en_us]=<Misc>
		</type>
  </flameshot0>
</sessions>
<sessions>
	<appspace%>
		extends_base=<sessions.base%>
		node_action=<wm_postsetup>
	</appspace%>
  <appspace0>
		<name_localized>
			displayname[en_us]=<Appspace App>
		</name_localized>
		<icon>
            value=</services/appspace/.icons/monochrome.png>
		</icon>
		<type>
			displayname[en_us]=<Misc>
		</type>
  </appspace0>
</sessions>
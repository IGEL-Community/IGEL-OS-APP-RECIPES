<sessions>
	<sapgui%>
		extends_base=<sessions.base%>
		node_action=<wm_postsetup>
	</sapgui%>
  <sapgui0>
		<name_localized>
			displayname[en_us]=<SAPGUI>
		</name_localized>
		<icon>
            value=</services/sapgui/.icons/app.png>
		</icon>
		<type>
			displayname[en_us]=<Misc>
		</type>
  </sapgui0>
</sessions>